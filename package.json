{
  "name": "testbraillerap",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "npm-run-all": "^4.1.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-scripts": "5.0.1",
    "tailwindcss": "^4.3.2",
    "web-vitals": "^2.1.4",
    "eslint-config-react-app": "^7.0.1",
    "@babel/plugin-transform-private-property-in-object": "^7.28.6"
  },
  "scripts": {
    "clean": "rm -rf build dist",
    "start": "react-scripts start",
    "build": "react-scripts build",
    "builddev": "cross-env GENERATE_SOURCEMAP=true  npm-run-all clean tailwindbuildmini build",
    "test": "react-scripts test",
    "webview": "python testbraillerap.py --debug",
    "tailwindbuildlocal": "npx tailwindcss -i tailwind/style.css -c tailwind/tailwind.config.js -o ./src/index.css",
    "tailwindbuildmini": "npx tailwindcss -i tailwind/style.css -c tailwind/tailwind.config.js -o src/index.css --minify",
    "tailwindwatch": "npx tailwindcss -i tailwind/style.css -c tailwind/tailwind.config.js -o src/index.css --watch",
    "debugcss": "cross-env REACT_APP_FEATURES_FOR_DEBUG=true npm-run-all tailwindbuildlocal start",
    "startview": "cross-env REACT_APP_FEATURES_FOR_DEBUG=false npm-run-all tailwindbuildmini build webview",
    "debugview": "cross-env REACT_APP_FEATURES_FOR_DEBUG=true npm-run-all tailwindbuildlocal builddev webview",

    "package": "pyinstaller TestBrailleRAP.spec",
    "packageportable": "pyinstaller TestBrailleRAPPortable.spec",
    "buildportable": "npm-run-all clean tailwindbuildmini build packageportable",
    "buildview": "npm-run-all clean tailwindbuildmini build package",

    "mkdirdebian": "mkdir -p ./package/debian/testbraillerap-debian/usr/bin/",
    "packagedebian": "pyinstaller DebianTestBrailleRAP.spec",
    "clogdebian": "git-changelog -x -s v0.0.0 -f `git tag | tail -n 1` | gzip > ./package/debian/testbraillerap-debian/usr/share/doc/testbraillerap-debian/changelog.gz",
    "cpdebian": "cp ./dist/testbraillerap-debian ./package/debian/testbraillerap-debian/usr/bin/",
    "dpkg-debian": "dpkg-deb -v --root-owner-group --build ./package/debian/testbraillerap-debian ./dist/testbraillerap-debian-${npm_package_version}.deb",
    "checkdebian": "lintian ./dist/testbraillerap-debian-${npm_package_version}.deb",
    "dpkg-debian13": "dpkg-deb -v --root-owner-group --build ./package/debian/testbraillerap-debian ./dist/testbraillerap-debian13-${npm_package_version}.deb",
    "checkdebian13": "lintian ./dist/testbraillerap-debian13-${npm_package_version}.deb",
    "build-deb-debian13": "npm-run-all mkdirdebian cpdebian clogdebian dpkg-debian13 checkdebian13",
    "builddebian13": "npm-run-all clean tailwindbuildmini build packagedebian build-deb-debian13",

    "mkdirubuntu": "mkdir -p ./package/ubuntu/testbraillerap-ubuntu/usr/bin/",
    "clogubuntu": "git-changelog -x -s v0.0.0 -f `git tag | tail -n 1` | gzip > ./package/ubuntu/testbraillerap-ubuntu/usr/share/doc/testbraillerap-ubuntu/changelog.gz",
    "treeubuntu": "tree -a ./package/ubuntu",
    "checktar": "tar -cvzf ./dist/test.gz ./package/ubuntu/testbraillerap-ubuntu",
    "cpubuntu": "cp ./dist/testbraillerap-ubuntu ./package/ubuntu/testbraillerap-ubuntu/usr/bin/",
    "dpkg-ubuntu": "dpkg-deb -v --root-owner-group --build ./package/ubuntu/testbraillerap-ubuntu ./dist/testbraillerap-ubuntu-${npm_package_version}.deb",
    "checkubuntu": "lintian ./dist/testbraillerap-ubuntu-${npm_package_version}.deb",
    "build-deb-ubuntu": "npm-run-all mkdirubuntu cpubuntu clogubuntu treeubuntu checktar dpkg-ubuntu checkubuntu",
    "packageubuntu": "pyinstaller UbuntuTestBrailleRAP.spec",
    "buildubuntu": "npm-run-all clean tailwindbuildmini build packageubuntu build-deb-ubuntu"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
